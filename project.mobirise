                "image": "@PROJECT_PATH@/assets/images/d09dd0bed0b2d0b8d0b920d0bfd180d0bed194d0bad182202-2000x1186.jpg",
                "thumb": "@PROJECT_PATH@/assets/images/d09dd0bed0b2d0b8d0b920d0bfd180d0bed194d0bad182202-2000x1186-800x474.jpg",
                "alt": "",
