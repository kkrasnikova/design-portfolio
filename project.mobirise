                "videoPreview": "@THEME_PATH@/components/_images/gallery/preview.jpg",
                "playVideo": false,
                "videoUrl": "https://www.youtube.com/watch?v=fwkKc6M60-0",
                "image": "@PROJECT_PATH@/assets/images/d09dd0bed0b2d0b8d0b920d0bfd180d0bed194d0bad182201-2000x2149.jpg",
                "thumb": "@PROJECT_PATH@/assets/images/d09dd0bed0b2d0b8d0b920d0bfd180d0bed194d0bad182201-2000x2149-800x860.jpg",
