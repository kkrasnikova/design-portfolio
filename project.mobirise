                "image": "@PROJECT_PATH@/assets/images/d09dd0bed0b2d0b8d0b920d0bfd180d0bed194d0bad182203-2000x1553.jpg",
                "thumb": "@PROJECT_PATH@/assets/images/d09dd0bed0b2d0b8d0b920d0bfd180d0bed194d0bad182203-2000x1553-800x621.jpg",
                "alt": "",
